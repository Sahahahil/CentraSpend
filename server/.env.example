# Copy to .env and adjust as needed:
#   cp .env.example .env

# Local development (recommended — requires MongoDB running locally)
USE_LOCAL_MONGO=true
MONGO_URI=mongodb://127.0.0.1:27017/expense_tracker

# Or use MongoDB Atlas (whitelist your IP in Atlas → Network Access)
# USE_LOCAL_MONGO=false
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/expense_tracker?retryWrites=true&w=majority

JWT_SECRET=change-me-in-production
